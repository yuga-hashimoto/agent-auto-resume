{
  "name": "agent-auto-resume",
  "version": "0.1.17",
  "description": "Daemon-based auto-resume for Claude Code, Codex CLI, and Antigravity CLI after provider-declared usage limits reset.",
  "type": "module",
  "bin": {
    "aar": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "claude-code",
    "codex",
    "openai-codex",
    "antigravity",
    "antigravity-cli",
    "agy",
    "google-antigravity",
    "gemini",
    "auto-resume",
    "daemon",
    "rate-limit",
    "usage-limit",
    "quota-limit",
    "cli",
    "developer-tools",
    "agent",
    "ai-agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "nanoid": "^5.0.7",
    "node-pty": "^1.1.0-beta21",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.9",
    "tsup": "^8.1.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
